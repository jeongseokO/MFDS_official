# Copy this file to .env and fill in values for your server.
# Never commit .env because it may contain private tokens or local paths.

# Python executable inside the conda environment.
PYTHON_BIN=/absolute/path/to/conda/envs/mfds_official/bin/python

# Hugging Face token. Required for private SKIML model/adapter repositories.
# Fill this in after copying to .env. Never commit the real token.
HF_TOKEN=

# Cache location for Hugging Face models. Use a large shared disk on the server.
HF_HOME=/absolute/path/to/huggingface_cache

# Korean -> English and English -> Korean private LoRA adapter repos.
FEWSHOT_BASELINE_MODEL_KO_EN=SKIML/mfds-vaivgem-ko-en-fewshot-lora
FEWSHOT_BASELINE_MODEL_EN_KO=SKIML/mfds-vaivgem-en-ko-fewshot-lora

# Optional: override the base model if adapter_config.json points to a path
# that does not exist on the target server.
# HF2_BASE_MODEL=/absolute/path/to/base_model_or_hf_repo_id

# Few-shot retrieval FAISS prefix. The app will append _ko_to_en or _en_to_ko.
# Example expected directories:
#   ${MFDS_FAISS_DB_ROOT}_ko_to_en/
#   ${MFDS_FAISS_DB_ROOT}_en_to_ko/
MFDS_FAISS_DB_ROOT=/absolute/path/to/faiss/dev_with_doc_id

# Gradio and GPU settings.
GRADIO_HOST=0.0.0.0
PORT=7860
APP_DIRECTIONS=ko_en,en_ko
APP_METHODS=fewshot_baseline,segment_mt
MFDS_GRADIO_SHARED_LORA=1
GPU_MEM_UTIL=0.6
BATCH_SIZE=64
MAX_FEWSHOT=30

# ngrok static domain if your account has one. Leave empty for a random free URL.
NGROK_STATIC_DOMAIN=
